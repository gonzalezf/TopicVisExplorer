{
  "name": "@topicvisexplorer/frontend",
  "version": "1.0.0-alpha.0",
  "private": true,
  "description": "Vite + TypeScript frontend bundle for TopicVisExplorer. Wraps the legacy D3 v5 visualization code (LDAvis, topicflow, sankey) and ships a single hashed-free bundle into src/topicvisexplorer/web/dist/ so the Python wheel can serve it.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:no-typecheck": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx,.js",
    "format": "prettier --write src",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "bootstrap": "4.5.0",
    "bootstrap-table": "1.18.3",
    "d3": "5.16.0",
    "d3-sankey": "0.12.3",
    "intro.js": "4.3.0",
    "jquery": "3.5.1",
    "lodash": "4.17.21",
    "mark.js": "8.11.1",
    "nouislider": "14.6.2",
    "popper.js": "1.16.1"
  },
  "devDependencies": {
    "@playwright/test": "1.47.0",
    "@types/d3": "5.16.7",
    "@types/d3-sankey": "0.12.4",
    "@types/jquery": "3.5.30",
    "@types/lodash": "4.17.7",
    "@types/node": "20.16.5",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.0",
    "prettier": "3.3.3",
    "sass-embedded": "1.78.0",
    "typescript": "5.5.4",
    "vite": "5.4.6"
  }
}
